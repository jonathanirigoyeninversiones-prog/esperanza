<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A2E"
    android:padding="8dp">
    <TextView
        android:id="@+id/display"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="bottom|end"
        android:text="0"
        android:textSize="48sp"
        android:textColor="#FFFFFF"
        android:background="#16213E"
        android:padding="16dp"
        android:layout_marginBottom="8dp" />
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="4"
        android:columnCount="4"
        android:rowCount="7"
        android:alignmentMode="alignMargins"
        android:columnOrderPreserved="false">
        <Button android:id="@+id/btnC" android:text="C" android:layout_columnSpan="1" android:layout_rowSpan="1" android:layout_margin="4dp" android:textSize="18sp" android:background="#E94560" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btnBack" android:text="⌫" android:layout_margin="4dp" android:textSize="18sp" android:background="#533483" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btnLeftParen" android:text="(" android:layout_margin="4dp" android:textSize="18sp" android:background="#0F3460" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btnRightParen" android:text=")" android:layout_margin="4dp" android:textSize="18sp" android:background="#0F3460" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btnSin" android:text="sin" android:layout_margin="4dp" android:textSize="16sp" android:background="#0F3460" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btnCos" android:text="cos" android:layout_margin="4dp" android:textSize="16sp" android:background="#0F3460" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btnTan" android:text="tan" android:layout_margin="4dp" android:textSize="16sp" android:background="#0F3460" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btnLog" android:text="log" android:layout_margin="4dp" android:textSize="16sp" android:background="#0F3460" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btn7" android:text="7" android:layout_margin="4dp" android:textSize="22sp" android:background="#533483" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btn8" android:text="8" android:layout_margin="4dp" android:textSize="22sp" android:background="#533483" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btn9" android:text="9" android:layout_margin="4dp" android:textSize="22sp" android:background="#533483" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btnDivide" android:text="÷" android:layout_margin="4dp" android:textSize="22sp" android:background="#E94560" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btn4" android:text="4" android:layout_margin="4dp" android:textSize="22sp" android:background="#533483" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btn5" android:text="5" android:layout_margin="4dp" android:textSize="22sp" android:background="#533483" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btn6" android:text="6" android:layout_margin="4dp" android:textSize="22sp" android:background="#533483" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btnMultiply" android:text="×" android:layout_margin="4dp" android:textSize="22sp" android:background="#E94560" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btn1" android:text="1" android:layout_margin="4dp" android:textSize="22sp" android:background="#533483" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btn2" android:text="2" android:layout_margin="4dp" android:textSize="22sp" android:background="#533483" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btn3" android:text="3" android:layout_margin="4dp" android:textSize="22sp" android:background="#533483" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btnMinus" android:text="-" android:layout_margin="4dp" android:textSize="22sp" android:background="#E94560" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btn0" android:text="0" android:layout_margin="4dp" android:textSize="22sp" android:background="#533483" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btnDot" android:text="." android:layout_margin="4dp" android:textSize="22sp" android:background="#533483" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btnEqual" android:text="=" android:layout_margin="4dp" android:textSize="22sp" android:background="#E94560" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btnPlus" android:text="+" android:layout_margin="4dp" android:textSize="22sp" android:background="#E94560" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btnPi" android:text="π" android:layout_margin="4dp" android:textSize="18sp" android:background="#0F3460" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btnE" android:text="e" android:layout_margin="4dp" android:textSize="18sp" android:background="#0F3460" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btnSquare" android:text="x²" android:layout_margin="4dp" android:textSize="18sp" android:background="#0F3460" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btnSqrt" android:text="√" android:layout_margin="4dp" android:textSize="18sp" android:background="#0F3460" android:textColor="#FFFFFF"/>
    </GridLayout>
</LinearLayout>
